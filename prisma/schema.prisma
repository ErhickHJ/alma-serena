generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String   @default("")
  message   String
  createdAt DateTime @default(now())
}

model PartnerRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String   @default("")
  website   String   @default("")
  message   String   @default("")
  createdAt DateTime @default(now())
}

model Order {
  id            String   @id @default(cuid())
  clerkUserId   String?
  email         String
  name          String
  product       String   @default("libro")
  amount        Int      @default(0)
  status        String   @default("pending")
  paymentId     String?
  type          String   @default("store")
  partnerName   String   @default("")
  partnerContact String  @default("")
  commission    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String   @default("")
  createdAt DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String   @default("")
  content   String
  author    String   @default("Alma Serena")
  published Boolean  @default(false)
  imageUrl  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Float
  image     String   @default("")
  emoji     String   @default("")
  category  String   @default("")
  desc      String   @default("")
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ForumPost {
  id        String   @id @default(cuid())
  author    String
  clerkUserId String?
  text      String
  tag       String   @default("")
  createdAt DateTime @default(now())
}

model Referral {
  id              String   @id @default(cuid())
  referrerUserId  String
  referredUserId  String   @unique
  createdAt       DateTime @default(now())
}

model CommunityLeader {
  id            String   @id @default(cuid())
  clerkUserId   String   @unique
  name          String
  email         String   @default("")
  referralCount Int      @default(0)
  level         Int      @default(1)
  createdAt     DateTime @default(now())
}

model AdminLog {
  id        String   @id @default(cuid())
  userId    String
  email     String   @default("")
  action    String
  details   String   @default("")
  ip        String   @default("")
  createdAt DateTime @default(now())
}

model PartnerProduct {
  id             String   @id @default(cuid())
  name           String
  price          Int      @default(0)
  image          String   @default("")
  description    String   @default("")
  category       String   @default("")
  partnerName    String
  partnerContact String   @default("")
  commission     Int      @default(500)
  stock          Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Review {
  id           String   @id @default(cuid())
  productId    String
  clerkUserId  String?
  author       String
  rating       Int
  text         String   @default("")
  createdAt    DateTime @default(now())
}
